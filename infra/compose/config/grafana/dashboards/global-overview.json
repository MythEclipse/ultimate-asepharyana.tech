      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "thresholds" }, "unit": "percentunit", "min": 0, "max": 1, "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 0.05 }, { "color": "red", "value": 0.1 }] } }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 10 },
      "id": 11,
      "title": "Global Error Rate (5xx)",
      "type": "timeseries",
      "targets": [
        { "expr": "(sum(rate(elysia_http_requests_total{status_code=~\"5..\"}[5m])) + sum(rate(http_requests_total{status=~\"5..\"}[5m]))) / (sum(rate(elysia_http_requests_total[5m])) + sum(rate(http_requests_total[5m]))) or vector(0)", "legendFormat": "Combined 5xx" }
      ]
    }

